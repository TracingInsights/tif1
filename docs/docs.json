{
  "$schema": "https://mintlify.com/docs.json",
  "name": "tif1",
  "theme": "sequoia",
  "description": "High-performance Formula 1 data analysis for Python with a FastF1-compatible API.",
  "version": "0.1.0",
  "versions": ["latest", "0.1.0"],
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#15A83D",
    "light": "#15A83D",
    "dark": "#15A83D"
  },
  "fonts": {
    "heading": {
      "family": "Bebas Neue",
      "weight": 700
    },
    "body": {
      "family": "Roboto",
      "weight": 400
    }
  },
  "appearance": {
    "default": "system",
    "strict": false
  },
  "background": {
    "decoration": "grid",
    "color": {
      "light": "#EAF3FF",
      "dark": "#000000"
    }
  },
  "styling": {
    "eyebrows": "section",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    }
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/TracingInsights/tif1"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get started",
      "href": "https://github.com/TracingInsights/tif1#quickstart"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "installation",
              "getting-started",
              "quickstart",
              "examples",
              "migration-from-fastf1"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/best-practices",
              "guides/error-handling",
              "guides/data-visualization",
              "guides/common-use-cases"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/sessions",
              "concepts/backends",
              "concepts/caching-strategy",
              "concepts/cli",
              "concepts/jupyter",
              "concepts/data-flow"
            ]
          },

          {
            "group": "Reference",
            "pages": [
              "architecture",
              "reference/data-schema",
              "reference/environment-variables",
              "reference/cli-commands",
              "reference/faq",
              "reference/troubleshooting",
              "reference/contributing"
            ]
          }
        ]
      },
      {
        "tab": "Tutorials",
        "groups": [
          {
            "group": "Tutorials",
            "pages": [
              "tutorials/race-analysis",
              "tutorials/position-changes",
              "tutorials/race-pace-analysis",
              "tutorials/qualifying-analysis",
              "tutorials/qualifying-results",
              "tutorials/driver-laptimes",
              "tutorials/laptimes-distribution",
              "tutorials/laptime-heatmap",
              "tutorials/tire-strategy",
              "tutorials/tire-degradation",
              "tutorials/weather-impact",
              "tutorials/track-temperature",
              "tutorials/speed-traces",
              "tutorials/multi-driver-speed-comparison",
              "tutorials/annotated-speed-trace",
              "tutorials/gear-shifts-on-track",
              "tutorials/downforce-levels",
              "tutorials/throttle-distance",
              "tutorials/track-speed-map",
              "tutorials/track-throttle-map",
              "tutorials/track-brake-zones",
              "tutorials/track-acceleration-map",
              "tutorials/telemetry-comparison",
              "tutorials/gg-diagram",
              "tutorials/lap-delta-comparison",
              "tutorials/top-speeds",
              "tutorials/advanced-telemetry",
              "tutorials/data-export"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "api-reference/overview"
            ]
          },
          {
            "group": "Core API",
            "pages": [
              "api-reference/core",
              "api-reference/models",
              "api-reference/events",
              "api-reference/schedule"
            ]
          },
          {
            "group": "Data Pipeline",
            "pages": [
              "api-reference/io-pipeline",
              "api-reference/async-fetch",
              "api-reference/http",
              "api-reference/http-session",
              "api-reference/cdn"
            ]
          },
          {
            "group": "Configuration & Cache",
            "pages": [
              "api-reference/config",
              "api-reference/cache",
              "api-reference/retry"
            ]
          },
          {
            "group": "Visualization & Tools",
            "pages": [
              "api-reference/plotting",
              "api-reference/cli",
              "api-reference/jupyter"
            ]
          },
          {
            "group": "Utilities & Helpers",
            "pages": [
              "api-reference/utils",
              "api-reference/utilities",
              "api-reference/core-utils",
              "api-reference/types",
              "api-reference/validation",
              "api-reference/fuzzy",
              "api-reference/lap-operations"
            ]
          },
          {
            "group": "Compatibility & Errors",
            "pages": [
              "api-reference/fastf1-compat",
              "api-reference/exceptions"
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/TracingInsights/tif1"
    }
  },
  "seo": {
    "indexing": "all"
  },
  "analytics": {
    "ga4": {
      "measurementId": "G-XXXXXXXXXX"
    },
    "posthog": {
      "apiKey": "phc_XXXXXXXXXX"
    }
  },
  "banner": {
    "content": "⚡ tif1 is in active development. Join us on [GitHub](https://github.com/TracingInsights/tif1)!",
    "dismissible": true
  },
  "versionSelector": {
    "enabled": true,
    "position": "navbar"
  },
  "integrations": {
    "telemetry": {
      "enabled": true
    }
  },
  "metadata": {
    "timestamp": true
  },
  "interaction": {
    "drilldown": true
  }
}
