              "guides/working-with-large-datasets",
              "guides/production-deployment",
              "guides/data-visualization",
              "guides/integration-patterns",
              "guides/testing-strategies",
              "guides/common-use-cases"
            ]
          },
          {
            "group": "Concepts",
