{
  "$schema": "https://mintlify.com/docs.json",
  "name": "tif1",
  "theme": "sequoia",
  "description": "High-performance Formula 1 data analysis for Python with a FastF1-compatible API.",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#15A83D",
    "light": "#166E3F",
    "dark": "#15A83D"
  },
  "fonts": {
    "heading": {
      "family": "Bebas Neue",
      "weight": 700
    },
    "body": {
      "family": "Roboto",
      "weight": 400
    }
  },
  "appearance": {
    "default": "system",
    "strict": false
  },
  "background": {
    "decoration": "grid",
    "color": {
      "light": "#EAF3FF",
      "dark": "#000000"
    }
  },
  "styling": {
    "eyebrows": "section",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "github-dark"
      }
    }
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/TracingInsights/tif1"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get started",
      "href": "https://github.com/TracingInsights/tif1#quickstart"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "installation",
              "getting-started",
              "quickstart",
              "examples",
              "migration-from-fastf1"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/best-practices",
